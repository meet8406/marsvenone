{
  "permissions": {
    "allow": [
      "PowerShell(node --version)",
      "PowerShell(npm --version)",
      "PowerShell(\"---NODE---\")",
      "PowerShell(\"---NPM---\")",
      "PowerShell(npm install 2>&1)",
      "PowerShell(npm run build 2>&1)",
      "Bash(npm run *)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://localhost:5173/)",
      "Bash(curl -s http://localhost:5173/)"
    ]
  }
}
